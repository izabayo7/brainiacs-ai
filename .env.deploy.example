# Copy to .env on the deploy host (StrangeCloud VM) and fill in. Never commit the real .env.

# --- Domains (point DNS A records at the VM) ---
APP_DOMAIN=brainiacs.example.com           # the web app
API_DOMAIN=api.brainiacs.example.com       # the backend API
APP_URL=https://brainiacs.example.com      # = https://APP_DOMAIN
API_URL=https://api.brainiacs.example.com  # = https://API_DOMAIN  (baked into the web build)

# --- Secrets (generate strong random values) ---
DB_PASSWORD=change-me-strong
JWT_SECRET=change-me-long-random            # backend JWT signing
NEXTAUTH_SECRET=change-me-long-random       # NextAuth session encryption
AUTH_SYNC_SECRET=change-me-shared-secret    # SAME value used by web + api for Google sync

# --- Google OAuth (from Google Cloud; redirect URI = https://APP_DOMAIN/api/auth/callback/google) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- LLM (optional; without it the app uses the offline fallback) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
