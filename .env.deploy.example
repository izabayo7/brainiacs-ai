# Copy to .env on the deploy host (VM) and fill in. Never commit the real .env.

# --- URLs (must match your nginx server_name domains) ---
APP_URL=https://brainiacs.example.com      # the web app  (your APP domain, with https)
API_URL=https://api.brainiacs.example.com  # the backend API (baked into the web build)

# --- Secrets (generate strong random values, e.g. `openssl rand -hex 32`) ---
DB_PASSWORD=change-me-strong
JWT_SECRET=change-me-long-random            # backend JWT signing
NEXTAUTH_SECRET=change-me-long-random       # NextAuth session encryption

# Auth is email/password only — no Google OAuth, no external LLM (fully self-hosted).
