# Copy to .env and fill in. NEVER commit the real .env.

# --- LLM (Anthropic Claude) ---
# Demo uses the Anthropic API; production swaps in a self-hosted fine-tuned Qwen3.5-4B.
ANTHROPIC_API_KEY=
# Model id used for quiz-gen / grading / explanation.
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+psycopg://brainiacs:brainiacs@localhost:5432/brainiacs

# --- Frontend ---
# Base URL the Next.js app uses to reach the FastAPI backend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
