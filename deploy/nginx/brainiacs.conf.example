# Brainiacs AI — host nginx reverse proxy (TLS added by certbot).
#
# Setup:
#   1) replace APP_DOMAIN / API_DOMAIN below with your real domains
#   2) sudo cp deploy/nginx/brainiacs.conf.example /etc/nginx/sites-available/brainiacs
#      sudo ln -s /etc/nginx/sites-available/brainiacs /etc/nginx/sites-enabled/
#      sudo rm -f /etc/nginx/sites-enabled/default      # drop the default site
#   3) sudo nginx -t && sudo systemctl reload nginx
#   4) sudo certbot --nginx -d APP_DOMAIN -d API_DOMAIN  # adds HTTPS + http->https redirect

# Web app  ->  Next.js container (127.0.0.1:3000)
server {
    listen 80;
    server_name APP_DOMAIN;
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}

# API  ->  FastAPI container (127.0.0.1:8000)
server {
    listen 80;
    server_name API_DOMAIN;
    client_max_body_size 5m;
    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
